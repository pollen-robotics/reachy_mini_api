# Reachy Mini Website server env vars
#
# Copy this file to `.env` and fill in the values for local dev.
# In production (HF Space), set these from the Space's "Settings →
# Variables and secrets" panel, NOT from a committed `.env`.
# (`.env` is gitignored.)

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port the Express server listens on. Defaults to 7860 (HF Space convention).
# PORT=7860

# -----------------------------------------------------------------------------
# OAuth (used by /api/oauth-config and the in-iframe sign-in flow)
# -----------------------------------------------------------------------------
# Set in the Space when `hf_oauth: true` is in README.md.
# OAUTH_CLIENT_ID=
# OAUTH_SCOPES=openid profile

# -----------------------------------------------------------------------------
# HF Inference Providers (used by /api/js-apps category inference)
# -----------------------------------------------------------------------------
# Required for category inference. A standard READ token is enough -
# Inference Providers access is on by default for FREE/PRO tokens.
# Without this, /api/js-apps still works but every entry will have
# `categories: null` (the route logs a warning at startup).
HF_TOKEN=

# -----------------------------------------------------------------------------
# Store control-plane dataset (single source of truth)
# -----------------------------------------------------------------------------
# One HF dataset drives the whole store catalog, via four sibling files:
#   app-list.json   - official app IDs   (hand-edited by Pollen)
#   block-list.json - blocked app IDs    (hand-edited killswitch)
#   categories.json - LLM category cache (written by the server)
#   moderation.json - moderation verdict cache (written by the server)
#
# IMPORTANT: the server WRITES categories.json + moderation.json, so the
# HF_TOKEN above must have WRITE access to this dataset. The two
# hand-edited lists are read-only from the server - anyone with dataset
# write access can promote (app-list) or block (block-list) an app.
# Defaults to the existing official dataset; point it anywhere to move
# all four files at once.
# STORE_DATASET=pollen-robotics/reachy-mini-official-app-store

# Advanced escape hatches: override ONLY one file's dataset, leaving the
# others on STORE_DATASET. Rarely needed - prefer STORE_DATASET.
# HF_CATEGORIES_DATASET=
# HF_MODERATION_DATASET=

# -----------------------------------------------------------------------------
# Mobile catalog moderation (used by /api/js-apps)
# -----------------------------------------------------------------------------
# Moderation is always on and fail-closed: the catalog shows ONLY apps
# whose regex+LLM verdict is an explicit `allow` (plus curated official
# apps). A `block`, a `review` (LLM unsure), an entry in
# block-list.json, or no verdict yet all keep the app hidden until
# moderation has explicitly cleared it - a new Space never appears
# before it has been moderated. Uses the same HF_TOKEN + STORE_DATASET
# as category inference - no extra secret or dataset required.
# NOTE: without HF_TOKEN the LLM batch can't run, so non-official apps
# stay hidden. Set it in .env or the Space secrets in production.

# -----------------------------------------------------------------------------
# OpenAI Realtime ephemeral keys (used by /api/openai/ephemeral)
# -----------------------------------------------------------------------------
# Master OpenAI API key. Used SERVER-SIDE only to mint short-lived
# (~1 minute) `client_secret.value` tokens for the Reachy Mini mobile
# shell's voice conversation feature. NEVER expose this to a client
# bundle. The mobile client never sees this value: it posts its HF
# Bearer token, gets back an ephemeral session key scoped to a single
# OpenAI Realtime session.
OPENAI_API_KEY=

# Optional: pin the Realtime model id. Defaults to
# `gpt-4o-realtime-preview-2024-12-17`. Bumping this requires
# coordinating with the mobile shell, which is built against a
# specific protocol version.
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# Optional: max ephemeral mints per HF user per rolling hour.
# Defaults to 60. The in-memory sliding-window limiter resets on
# Space restart; v1 takes the trade-off, replace with a shared KV
# the day we need multi-replica fairness.
# OPENAI_EPHEMERAL_RATE_LIMIT_PER_HOUR=60
